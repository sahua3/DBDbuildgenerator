# DB
POSTGRES_USER=dbd
POSTGRES_PASSWORD=dbdpassword
POSTGRES_DB=dbd_builds
DATABASE_URL=postgresql+asyncpg://dbd:dbdpassword@postgres:5432/dbd_builds

# redis
REDIS_URL=redis://redis:6379/0

# anthropic api (leave blank if you don't have one, will use placeholder answers)
ANTHROPIC_API_KEY=

# app
SECRET_KEY=change-me-in-production-please
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# scraping
NIGHTLIGHT_SCRAPE_INTERVAL_HOURS=6
SHRINE_SCRAPE_CRON_HOUR=12
SHRINE_SCRAPE_CRON_TIMEZONE=America/New_York